# Deny access to configuration files
<Files ".env">
    Order allow,deny
    Deny from all
</Files>

<Files "*.env">
    Order allow,deny
    Deny from all
</Files>

# Deny access to all PHP files in config directory
<Files "*.php">
    Order allow,deny
    Deny from all
</Files>

# Prevent directory listing
Options -Indexes

# Disable script execution
<FilesMatch "\.(php|phtml|php3|php4|php5|pl|py|cgi|sh|exe)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Only allow access to specific files if needed
# <Files "allowed-file.php">
#     Order allow,deny
#     Allow from all
# </Files>
