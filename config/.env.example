# HR Management System Environment Configuration Template

# Database Configuration
DB_HOST=localhost
DB_NAME=hr_management_system
DB_USER=root
DB_PASS=

# Application Settings
APP_NAME=HR Management System
APP_URL=http://localhost/HR-Management-System
APP_ENV=development

# Security Settings
ENCRYPTION_KEY=your-secret-encryption-key-here-change-this-in-production
JWT_SECRET=your-jwt-secret-key-here-change-this-in-production
SESSION_LIFETIME=3600
PASSWORD_MIN_LENGTH=8
MAX_LOGIN_ATTEMPTS=5

# File Upload Settings
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=pdf,doc,docx,jpg,jpeg,png

# Email Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_ENCRYPTION=tls
EMAIL_FROM=noreply@hrms.com
EMAIL_REPLY_TO=support@hrms.com

# Company Information
COMPANY_NAME=Your Company Name
COMPANY_ADDRESS=123 Business St, City, State 12345
COMPANY_PHONE=+1 (555) 123-4567
COMPANY_EMAIL=info@company.com

# Timezone
TIMEZONE=Asia/Kolkata

# Development Settings (only for development environment)
DEBUG=true
LOG_LEVEL=DEBUG
